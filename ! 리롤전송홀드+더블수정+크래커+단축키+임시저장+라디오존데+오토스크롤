(function () {
    'use strict';

    // ==========================================
    // 모듈 1: 더블클릭 수정 기능
    // ==========================================
    function initDoubleClick() {
        function findMessageContainer(target) {
            let el = target;
            while (el && el !== document.body) {
                if (el.hasAttribute('data-message-group-id')) return el;
                el = el.parentElement;
            }
            return null;
        }

        function getReactProps(el) {
            const key = Object.keys(el).find(k => k.startsWith('__reactProps'));
            return key ? el[key] : null;
        }

        function firePointerClick(el) {
            const opts = { bubbles: true, cancelable: true };
            el.dispatchEvent(new PointerEvent('pointerover', opts));
            el.dispatchEvent(new PointerEvent('pointerenter', opts));
            el.dispatchEvent(new MouseEvent('mouseenter', opts));
            el.dispatchEvent(new PointerEvent('pointerdown', opts));
            el.dispatchEvent(new PointerEvent('pointerup', opts));
            el.click();
        }

        function tryReactEditClick(container) {
            const trigger = container.querySelector('div[aria-haspopup="menu"]');
            if (!trigger) return false;

            const style = document.createElement('style');
            style.id = 'igx-hide-dropdown';
            style.textContent = `[data-radix-popper-content-wrapper], [role="menu"] { opacity: 0 !important; pointer-events: none !important; }`;
            document.head.appendChild(style);

            firePointerClick(trigger);

            const start = Date.now();
            const timer = setInterval(() => {
                const item = Array.from(document.querySelectorAll('div[role="menuitem"]')).find(el => el.textContent.includes('수정'));
                if (item) {
                    clearInterval(timer);
                    const props = getReactProps(item);
                    if (props?.onSelect) props.onSelect();
                    else firePointerClick(item);
                    setTimeout(() => style.remove(), 100);
                } else if (Date.now() - start > 1500) {
                    clearInterval(timer);
                    style.remove();
                }
            }, 30);
            return true;
        }

        document.addEventListener('dblclick', (e) => {
            const container = findMessageContainer(e.target);
            if (!container) return;
            window.getSelection().removeAllRanges();
            tryReactEditClick(container);
        });
    }

    // ==========================================
    // 모듈 2: 리롤 길게 누르기 기능
    // ==========================================
    function initRerollHold() {
        const HOLD_MS = 600;
        let isConfirmed = false;
        let holdTimer = null;

        const css = `
            #rr-progress-ring { position: fixed; pointer-events: none; z-index: 999999; display: none; }
            #rr-progress-ring.active { display: block; }
            #rr-progress-ring circle.track { fill: none; stroke: rgba(255,255,255,.15); stroke-width: 3; }
            #rr-progress-ring circle.fill { fill: none; stroke: #e8302a; stroke-width: 3; stroke-linecap: round; transform: rotate(-90deg); transform-origin: center; transform-box: fill-box; transition: stroke-dashoffset linear; }
        `;
        const styleEl = document.createElement('style');
        styleEl.textContent = css;
        document.head.appendChild(styleEl);

        const ring = document.createElement('div');
        ring.id = 'rr-progress-ring';
        ring.innerHTML = `<svg id="rr-svg"><circle class="track"/><circle class="fill"/></svg>`;
        document.body.appendChild(ring);

        const svg = ring.querySelector('svg');
        const trackCircle = ring.querySelector('circle.track');
        const fillCircle  = ring.querySelector('circle.fill');

        function isRerollBtn(el) {
            if (!el) return false;
            if (el.id === 'exp-reroll-btn') return true;
            return el.querySelector?.('svg path')?.getAttribute('d')?.startsWith('M3.8 12a8.2') ?? false;
        }

        function showRing(btn) {
            const rect = btn.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height);
            const cx = size / 2, cy = size / 2, r = (size / 2) - 2;
            const circumference = 2 * Math.PI * r;

            svg.setAttribute('width', size); svg.setAttribute('height', size);
            svg.setAttribute('viewBox', `0 0 ${size} ${size}`);
            trackCircle.setAttribute('cx', cx); trackCircle.setAttribute('cy', cy); trackCircle.setAttribute('r', r);
            fillCircle.setAttribute('cx', cx); fillCircle.setAttribute('cy', cy); fillCircle.setAttribute('r', r);
            fillCircle.style.strokeDasharray  = circumference;
            fillCircle.style.strokeDashoffset = circumference;

            ring.style.left = `${rect.left}px`; ring.style.top  = `${rect.top}px`;
            ring.classList.add('active');

            requestAnimationFrame(() => {
                fillCircle.style.transition = `stroke-dashoffset ${HOLD_MS}ms linear`;
                fillCircle.style.strokeDashoffset = '0';
            });
        }

        function hideRing() {
            ring.classList.remove('active');
            fillCircle.style.transition = 'none';
            if (fillCircle.style.strokeDasharray) fillCircle.style.strokeDashoffset = fillCircle.style.strokeDasharray;
        }

        function cancel() {
            if (!holdTimer) return;
            clearTimeout(holdTimer);
            holdTimer = null;
            hideRing();
        }

        document.addEventListener('click', (e) => {
            const btn = e.target.closest('button, [id="exp-reroll-btn"]');
            if (!isRerollBtn(btn)) return;
            if (isConfirmed) { isConfirmed = false; return; }
            e.preventDefault(); e.stopPropagation(); e.stopImmediatePropagation();
        }, true);

        document.addEventListener('mousedown', (e) => {
            const btn = e.target.closest('button, [id="exp-reroll-btn"]');
            if (!isRerollBtn(btn)) return;
            showRing(btn);
            holdTimer = setTimeout(() => { hideRing(); isConfirmed = true; btn.click(); holdTimer = null; }, HOLD_MS);
        });

        document.addEventListener('mouseup', cancel);
        document.addEventListener('mouseleave', cancel);
        document.addEventListener('touchstart', (e) => {
            const btn = e.target.closest('button, [id="exp-reroll-btn"]');
            if (!isRerollBtn(btn)) return;
            e.preventDefault(); showRing(btn);
            holdTimer = setTimeout(() => { hideRing(); isConfirmed = true; btn.click(); holdTimer = null; }, HOLD_MS);
        }, { passive: false });
        document.addEventListener('touchend', cancel);
        document.addEventListener('touchcancel', cancel);
    }

    // ==========================================
    // 모듈 3: 전송/이어서 생성 길게 누르기 기능
    // ==========================================
    function initSendHold() {
        const HOLD_MS = 600;
        let isConfirmed = false;
        let holdTimer = null;

        const css = `
            #sh-progress-ring { position: fixed; pointer-events: none; z-index: 999999; display: none; }
            #sh-progress-ring.active { display: block; }
            #sh-progress-ring circle.track { fill: none; stroke: rgba(255,255,255,.15); stroke-width: 3; }
            #sh-progress-ring circle.fill { fill: none; stroke: #f97316; stroke-width: 3; stroke-linecap: round; transform: rotate(-90deg); transform-origin: center; transform-box: fill-box; transition: stroke-dashoffset linear; }
        `;
        const styleEl = document.createElement('style');
        styleEl.textContent = css;
        document.head.appendChild(styleEl);

        const ring = document.createElement('div');
        ring.id = 'sh-progress-ring';
        ring.innerHTML = `<svg id="sh-svg"><circle class="track"/><circle class="fill"/></svg>`;
        document.body.appendChild(ring);

        const svg = ring.querySelector('svg');
        const trackCircle = ring.querySelector('circle.track');
        const fillCircle  = ring.querySelector('circle.fill');

        function isStopButton(btn) {
            const path = btn.querySelector('svg path');
            const d = path?.getAttribute('d') || '';
            return d.includes('M6 6h12v12H6Z');
        }

        function isGeneralSendButton(btn) {
            if (!btn) return false;
            const cls = btn.className || '';
            return (
                cls.includes('bg-primary') &&
                cls.includes('rounded-full') &&
                cls.includes('text-primary-foreground')
            );
        }

        function isHoldableSendBtn(el) {
            return isGeneralSendButton(el) && !isStopButton(el);
        }

        function showRing(btn) {
            const rect = btn.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height) + 4;
            const cx = size / 2, cy = size / 2, r = (size / 2) - 2;
            const circumference = 2 * Math.PI * r;

            svg.setAttribute('width', size); svg.setAttribute('height', size);
            svg.setAttribute('viewBox', `0 0 ${size} ${size}`);
            trackCircle.setAttribute('cx', cx); trackCircle.setAttribute('cy', cy); trackCircle.setAttribute('r', r);
            fillCircle.setAttribute('cx', cx); fillCircle.setAttribute('cy', cy); fillCircle.setAttribute('r', r);
            fillCircle.style.strokeDasharray  = circumference;
            fillCircle.style.strokeDashoffset = circumference;

            ring.style.left = `${rect.left - 2}px`; ring.style.top  = `${rect.top - 2}px`;
            ring.classList.add('active');

            requestAnimationFrame(() => {
                fillCircle.style.transition = `stroke-dashoffset ${HOLD_MS}ms linear`;
                fillCircle.style.strokeDashoffset = '0';
            });
        }

        function hideRing() {
            ring.classList.remove('active');
            fillCircle.style.transition = 'none';
            if (fillCircle.style.strokeDasharray) fillCircle.style.strokeDashoffset = fillCircle.style.strokeDasharray;
        }

        function cancel() {
            if (!holdTimer) return;
            clearTimeout(holdTimer);
            holdTimer = null;
            hideRing();
        }

        document.addEventListener('click', (e) => {
            const btn = e.target.closest('button');
            if (!isHoldableSendBtn(btn)) return;
            if (isConfirmed) { isConfirmed = false; return; }
            e.preventDefault(); e.stopPropagation(); e.stopImmediatePropagation();
        }, true);

        function handlePressStart(e) {
            const btn = e.target.closest('button');
            if (!isHoldableSendBtn(btn)) return;
            if (e.type === 'touchstart') e.preventDefault();
            showRing(btn);
            holdTimer = setTimeout(() => { hideRing(); isConfirmed = true; btn.click(); holdTimer = null; }, HOLD_MS);
        }

        document.addEventListener('mousedown', handlePressStart);
        document.addEventListener('mouseup', cancel);
        document.addEventListener('mouseleave', cancel);
        document.addEventListener('touchstart', handlePressStart, { passive: false });
        document.addEventListener('touchend', cancel);
        document.addEventListener('touchcancel', cancel);
    }

    // ==========================================
    // 모듈 4: 외부 좌측 배치 턴수 & 크래커 표시기
    // ==========================================
    function initTurnCracker() {
        const SELECTOR = {
            input: 'textarea[placeholder*="메시지"], div.__chat_input_textarea[contenteditable="true"], .tiptap.ProseMirror',
            messageGroup: 'div[data-message-group-id]'
        };

        const CRACKER_PATH = "M21.17 12.01c.52-.59.83-1.36.83-2.21s-.31-1.62-.83-2.21l.17-.21q0-.01.02-.02l.14-.21q0-.02.03-.05.06-.1.1-.2l.05-.08.09-.2q.01-.05.04-.11l.06-.18q0-.08.04-.14.01-.07.04-.16l.03-.19q0-.06.02-.13v-.33a3.37 3.37 0 0 0-3.36-3.37l-.33.01q-.06 0-.12.02-.1 0-.2.03-.07 0-.15.04l-.14.04-.18.06-.11.04-.2.09-.07.04-.2.11q-.03 0-.05.03l-.21.14-.02.02-.21.17a3.4 3.4 0 0 0-4.42 0 3.3 3.3 0 0 0-2.21-.83c-.85 0-1.62.31-2.21.83l-.21-.17-.02-.02-.21-.14q-.02 0-.05-.03l-.2-.11-.08-.04-.2-.09-.11-.04-.18-.06-.14-.04-.16-.04-.2-.03-.12-.02-.33-.01a3.37 3.37 0 0 0-3.34 3.82q0 .1.03.19 0 .07.04.16 0 .08.04.14l.06.18q0 .05.04.11.03.1.09.19l.04.08.1.2q.01.02.04.05l.16.23q.07.1.17.21a3.3 3.3 0 0 0-.83 2.21c0 .85.3 1.62.83 2.21a3.3 3.3 0 0 0-.83 2.21c0 .85.3 1.62.83 2.21l-.17.21-.02.02-.14.21q0 .02-.03.05l-.11.2-.04.08-.1.2-.03.11-.06.18-.04.14-.04.16-.03.19-.02.13-.01.33A3.4 3.4 0 0 0 3.02 21c.6.61 1.45.99 2.38.99l.33-.01q.06 0 .12-.02.1 0 .19-.03.07 0 .16-.04l.14-.04.18-.06.1-.04.2-.09.08-.04.2-.11q.03 0 .05.03l.2-.14.03-.02.2-.17a3.4 3.4 0 0 0 4.43 0 3.32 3.32 0 0 0 4.42 0 3 3 0 0 0 .44.33q.03 0 .05.03l.2.11.08.04.2.09.10.04.19.06.14.04.16.04.19.03.13.02.33.01c.92 0 1.75-.37 2.36-.97l.02-.02c.6-.61.99-1.45.99-2.38l-.01-.33q0-.06-.02-.12 0-.1-.03-.19 0-.07-.04-.16l-.04-.14-.06-.18-.04-.11-.1-.19-.03-.08-.11-.2q0-.02-.03-.05l-.14-.21-.02-.02-.17-.21c.52-.59.83-1.36.83-2.21s-.31-1.62-.83-2.21M7.5 13.5 6 12l1.5-1.5L9 12zM12 6l1.5 1.5L12 9l-1.5-1.5zm0 12-1.5-1.5L12 15l1.5 1.5zm4.5-4.5L15 12l1.5-1.5L18 12z";

        const ICON = {
            clock: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px; opacity:0.8;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`,
            cracker: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" style="margin-right:4px; opacity:1;"><path fill="currentColor" d="${CRACKER_PATH}"></path></svg>`,
            bittenCracker: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" style="margin-right:4px; color:#ff9b9b;"><defs><mask id="wrtn-crack-bite-mask"><rect width="24" height="24" fill="#ffffff" style="fill:#ffffff !important;" /><circle cx="24" cy="0" r="12" fill="#000000" style="fill:#000000 !important;" /></mask></defs><path fill="currentColor" mask="url(#wrtn-crack-bite-mask)" d="${CRACKER_PATH}"></path></svg>`
        };

        let counterBadge, textSpan, currentInput;
        let updateTimer, observer, lastRenderedText = '';
        let cachedTurns, cachedTotalMessages, isCalculatingTurns = false, lastCalculatedTime = 0, lastChatId;
        
        let lastKnownTotalCrackers = null;
        let lastConsumedAmount = 0;
        let lastProcessedTurns = -1;

        function start() {
            injectBaseStyle();
            startObserver();
            scheduleUpdate();
        }

        function injectBaseStyle() {
            if (document.getElementById('info-display-base-style')) return;
            const style = document.createElement('style');
            style.id = 'info-display-base-style';
            style.textContent = `
            #my-custom-info-display { position: absolute; box-sizing: border-box; font-family: 'Pretendard', sans-serif; font-size: 11px; font-weight: 500; pointer-events: none; z-index: 998; display: flex; align-items: center; border-radius: 12px; }
            #my-custom-info-display #my-counter-text { display: flex; align-items: center; gap: 0; }
            .my-counter-part { all: unset; display: inline-flex; align-items: center; border-radius: 4px; padding: 1px 4px; user-select: none; }
            .my-counter-separator { opacity: 0.3; margin: 0 2px; user-select: none; }
            `;
            document.head.appendChild(style);
        }

        function startObserver() {
            if (observer) return;
            observer = new MutationObserver((mutations) => {
                if (mutations.every(m => m.target.closest?.('#my-custom-info-display'))) return;
                scheduleUpdate();
            });
            observer.observe(document.body, { childList: true, subtree: true, characterData: true, attributes: true, attributeFilter: ['aria-valuenow'] });
        }

        function scheduleUpdate() { clearTimeout(updateTimer); updateTimer = setTimeout(updateTurnCount, 80); }

        function getThemeColors(el) {
            let bg = '#212121', current = el;
            while (current && current !== document.body) {
                const cBg = getComputedStyle(current).backgroundColor;
                if (cBg && cBg !== 'rgba(0, 0, 0, 0)' && cBg !== 'transparent') { bg = cBg; break; }
                current = current.parentElement;
            }
            const match = bg.match(/\d+/g);
            const isDark = match && match.length >= 3 ? (0.2126 * (+match[0]) + 0.7152 * (+match[1]) + 0.0722 * (+match[2])) < 128 : true;
            return { bg, text: isDark ? '#888' : '#777' };
        }

        function getCrackerCount() {
            const label = Array.from(document.querySelectorAll('span')).find(span => span.textContent.trim() === '나의 크래커');
            if (label?.nextElementSibling?.textContent.match(/[\d,]+/)) return parseInt(label.nextElementSibling.textContent.match(/[\d,]+/)[0].replace(/,/g, ''), 10);
            const topBar = document.getElementById('chasm-cracker-text');
            if (topBar) {
                const text = topBar.getAttribute('chasm-tmi-current') || topBar.textContent;
                const parsed = parseInt(String(text).replace(/,/g, ''), 10);
                if (!Number.isNaN(parsed)) return parsed;
            }
            return null;
        }

        function initUI(inputEl) {
            document.getElementById('my-custom-info-display')?.remove();
            lastRenderedText = ''; currentInput = inputEl;
            
            counterBadge = document.createElement('div'); counterBadge.id = 'my-custom-info-display';
            textSpan = document.createElement('span'); textSpan.id = 'my-counter-text';
            counterBadge.appendChild(textSpan); 
            
            const colors = getThemeColors(inputEl);
            counterBadge.style.color = colors.text;
            updateLayout(inputEl);
        }

        function updateLayout(inputEl) {
            if (!counterBadge) return;
            const container = inputEl.closest(".flex.w-full.flex-col.rounded-lg") || inputEl.closest(".flex.w-full.flex-col") || inputEl.parentElement;
            if (!container) return;

            if (counterBadge.parentElement !== container) {
                container.appendChild(counterBadge);
                container.style.position = 'relative';
            }

            counterBadge.style.top = '-26px';
            counterBadge.style.left = '4px';

            if (inputEl.style) {
                inputEl.style.removeProperty('padding-top');
                inputEl.style.removeProperty('min-height');
            }
        }

        async function fetchRoomData() {
            if (typeof CrackUtil === 'undefined') return { chatCounts: -1, totalMessages: -1 };
            try {
                const pathInfo = CrackUtil.path();
                if (!pathInfo.isChattingPath()) return { chatCounts: -1, totalMessages: -1 };
                const chatId = pathInfo.chatRoom();
                if (!chatId) return { chatCounts: -1, totalMessages: -1 };
                
                let chatCounts = 0; 
                let totalMessages = 0;
                for await (let log of CrackUtil.chatRoom().iterateLogs(chatId)) {
                    totalMessages++;
                    if (log.isUser()) chatCounts++; 
                }
                return { chatCounts, totalMessages };
            } catch { return { chatCounts: -1, totalMessages: -1 }; }
        }

        function updateTurnCount() {
            const now = Date.now();
            const inputEl = document.querySelector(SELECTOR.input);
            if (!inputEl) { counterBadge?.remove(); counterBadge = null; currentInput = null; return; }
            if (!counterBadge || currentInput !== inputEl || !counterBadge.parentElement) initUI(inputEl);
            if (!counterBadge || !textSpan) return;
            const currentChatId = typeof CrackUtil !== 'undefined' ? CrackUtil.path().chatRoom() : null;
            let forceCalculate = false;
            
            if (currentChatId && currentChatId !== lastChatId) { 
                lastChatId = currentChatId; 
                forceCalculate = true; 
                cachedTurns = null; 
                cachedTotalMessages = null; 
                lastConsumedAmount = 0; 
                lastProcessedTurns = -1; 
            }

            if (!isCalculatingTurns && (forceCalculate || now - lastCalculatedTime > 1500)) {
                isCalculatingTurns = true;
                fetchRoomData().then(data => {
                    const domTotalMessages = document.querySelectorAll(SELECTOR.messageGroup).length;
                    if (data.chatCounts !== -1) {
                        if (data.chatCounts === 0 && data.totalMessages <= 0 && domTotalMessages > 0) {
                            cachedTurns = Math.floor(domTotalMessages / 2);
                            cachedTotalMessages = domTotalMessages;
                        } else {
                            cachedTurns = data.chatCounts;
                            cachedTotalMessages = data.totalMessages !== -1 ? data.totalMessages : null;
                        }
                        if (cachedTurns !== lastProcessedTurns) {
                            lastProcessedTurns = cachedTurns;
                            renderUpdate(inputEl);
                        }
                    } else { 
                        cachedTotalMessages = domTotalMessages;
                        cachedTurns = Math.floor(domTotalMessages / 2); 
                    }
                    lastCalculatedTime = Date.now(); isCalculatingTurns = false; renderUpdate(inputEl);
                }).catch(() => { isCalculatingTurns = false; renderUpdate(inputEl); });
            } else { renderUpdate(inputEl); }
        }

        function renderUpdate(inputEl) {
            if (!textSpan) return;
            let displayTurns = cachedTurns ?? Math.floor(document.querySelectorAll(SELECTOR.messageGroup).length / 2);
            let html = '';

            html += `<div class="my-counter-part">${ICON.clock}<span style="font-weight:700;">${displayTurns > 0 ? displayTurns : '0'}</span>턴</div>`;

            const crackerCount = getCrackerCount();
            if (crackerCount !== null) {
                if (lastKnownTotalCrackers === null) {
                    lastKnownTotalCrackers = crackerCount; 
                } else if (crackerCount < lastKnownTotalCrackers) {
                    lastConsumedAmount = lastKnownTotalCrackers - crackerCount;
                    lastKnownTotalCrackers = crackerCount; 
                } else if (crackerCount > lastKnownTotalCrackers) {
                    lastKnownTotalCrackers = crackerCount;
                }

                html += `<span class="my-counter-separator">|</span>`;
                html += `<div class="my-counter-part" style="color: #FFA600;">${ICON.cracker}<span style="font-weight:700;">${crackerCount.toLocaleString()}</span>개</div>`;
            }

            html += `<span class="my-counter-separator">|</span>`;
            html += `<div class="my-counter-part" style="color:#ff9b9b;">${ICON.bittenCracker}<span style="font-weight:700;">${lastConsumedAmount}</span>개</div>`;

            if (html !== lastRenderedText) {
                textSpan.innerHTML = html;
                lastRenderedText = html;
            }
            updateLayout(inputEl);
        }
        start();
    }

    // ==========================================
    // 모듈 5: 고정형 RP 대사 입력 도우미 (커서 위치 수정 버전)
    // ==========================================
    function initRPToolbar() {
        const fixedTools = [
            { icon: '★', pre: '*', suf: '*' },
            { icon: '♠', pre: '"', suf: '"' },
            { icon: '♤', pre: "'", suf: "'" },
            { icon: '◆', pre: '`', suf: '`' },
            { icon: '■', pre: '[', suf: ']' },
            { icon: '♣', pre: '(!', suf: ')' },
            { icon: '♧', pre: '(OOC：', suf: ')' }
        ];

        if (!document.getElementById('hide-native-rp-btns')) {
            const style = document.createElement('style');
            style.id = 'hide-native-rp-btns';
            style.textContent = `
                .igx-rp-container-hooked > button:not(.igx-keep-btn) {
                    display: none !important;
                }
            `;
            document.head.appendChild(style);
        }

        function wrapText(prefix, suffix) {
            const inputEl = document.querySelector('textarea, div.__chat_input_textarea[contenteditable="true"], .tiptap.ProseMirror');
            if (!inputEl) return;

            // 새로운 문서 편집기 형태(contenteditable)인 경우
            if (inputEl.tagName !== 'TEXTAREA' && inputEl.isContentEditable) {
                inputEl.focus();
                const selection = window.getSelection();
                if (!selection.rangeCount) return;

                const range = selection.getRangeAt(0);
                const selectedText = selection.toString();
                const fullText = prefix + selectedText + suffix;

                // 텍스트 삽입
                document.execCommand("insertText", false, fullText);

                // 커서를 suffix 이전으로 수동 이동 (뒤에서부터 한 글자씩 왼쪽으로)
                for (let i = 0; i < suffix.length; i++) {
                    selection.modify("move", "backward", "character");
                }
                return;
            }

            // 기존 일반 텍스트 박스일 경우
            const start = inputEl.selectionStart || 0;
            const end = inputEl.selectionEnd || 0;
            const text = inputEl.value || '';
            const selected = text.substring(start, end);
            const before = text.substring(0, start);
            const after = text.substring(end, text.length);

            const newValue = before + prefix + selected + suffix + after;

            const nativeInputValueSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, "value").set;
            nativeInputValueSetter.call(inputEl, newValue);
            inputEl.dispatchEvent(new Event('input', { bubbles: true }));

            inputEl.focus();
            inputEl.setSelectionRange(start + prefix.length, end + prefix.length);
        }

        function createToolButton(iconText, onClick) {
            const btn = document.createElement('button');
            btn.className = "relative inline-flex items-center justify-center rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7";
            btn.type = "button";
            btn.innerHTML = `<span style="font-size:15px;">${iconText}</span>`;

            btn.onmousedown = (e) => e.preventDefault();
            btn.onclick = (e) => {
                e.preventDefault();
                onClick();
            };
            return btn;
        }

        document.addEventListener('keydown', (e) => {
            if (!e.altKey) return;
            let idx = -1;
            const code = e.code;
            const key = e.key;

            if (code === 'Backquote' || key === '`' || key === '~') idx = 0;
            else if (code === 'Digit1' || key === '1') idx = 1;
            else if (code === 'Digit2' || key === '2') idx = 2;
            else if (code === 'Digit3' || key === '3') idx = 3;
            else if (code === 'Digit4' || key === '4') idx = 4;
            else if (code === 'Digit5' || key === '5') idx = 5;
            else if (code === 'Digit6' || key === '6') idx = 6;

            if (idx !== -1) {
                const inputEl = document.querySelector('textarea, div.__chat_input_textarea[contenteditable="true"], .tiptap.ProseMirror');
                if (document.activeElement === inputEl || inputEl?.contains(document.activeElement)) {
                    if (fixedTools[idx]) {
                        e.preventDefault();
                        e.stopPropagation();
                        wrapText(fixedTools[idx].pre, fixedTools[idx].suf);
                    }
                }
            }
        }, true);

        setInterval(() => {
            const btnContainer = document.querySelector('.flex.items-center.space-x-2');
            if (!btnContainer) return;

            if (!btnContainer.classList.contains('igx-rp-container-hooked')) {
                btnContainer.classList.add('igx-rp-container-hooked');
            }

            const recommendBtn = Array.from(btnContainer.querySelectorAll('button')).find(btn => btn.textContent.includes('추천답변'));
            if (recommendBtn && !recommendBtn.classList.contains('igx-keep-btn')) {
                recommendBtn.classList.add('igx-keep-btn');
            }

            const slashBtn = Array.from(btnContainer.querySelectorAll('button')).find(btn => btn.textContent.trim() === '/');
            if (slashBtn && !slashBtn.classList.contains('igx-keep-btn')) {
                slashBtn.classList.add('igx-keep-btn');
            }

            let toolWrapper = document.getElementById('custom-rp-tools');

            if (!toolWrapper) {
                toolWrapper = document.createElement('div');
                toolWrapper.id = 'custom-rp-tools';
                toolWrapper.className = 'flex items-center gap-1';

                const autoScrollBtn = document.createElement('button');
                autoScrollBtn.id = 'turbo-scroll-btn';
                autoScrollBtn.className = "relative inline-flex items-center justify-center rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7";
                autoScrollBtn.innerHTML = `<span style="font-size:15px;">△</span>`;
                toolWrapper.appendChild(autoScrollBtn);

                if (slashBtn) {
                    toolWrapper.appendChild(slashBtn);
                }

                const divider = document.createElement('div');
                divider.className = 'custom-rp-divider'; 
                divider.style.width = '1px';
                divider.style.height = '14px';
                divider.style.borderLeft = '1px dashed currentColor';
                divider.style.opacity = '0.3';
                divider.style.margin = '0 8px';
                toolWrapper.appendChild(divider);

                fixedTools.forEach((t) => {
                    const btn = createToolButton(t.icon, () => wrapText(t.pre, t.suf));
                    toolWrapper.appendChild(btn);
                });

                if (recommendBtn) {
                    btnContainer.insertBefore(toolWrapper, recommendBtn);
                } else {
                    btnContainer.appendChild(toolWrapper);
                }
            } else {
                if (slashBtn && slashBtn.parentElement !== toolWrapper) {
                    const divider = toolWrapper.querySelector('.custom-rp-divider');
                    if (divider) {
                        toolWrapper.insertBefore(slashBtn, divider);
                    }
                }
            }
        }, 500);
    }

    // ==========================================
    // 모듈 6: 입력창 자동 임시저장
    // ==========================================
    function initAutoSaver() {
        function getRoomId() {
            const match = location.pathname.match(/\/stories\/[^/]+\/episodes\/([^/]+)/);
            return match ? match[1] : 'global_room';
        }

        function getDraftKey() {
            return 'crack_typing_draft_' + getRoomId();
        }

        let isRestoredForCurrentRoom = false;
        let currentRoomId = '';

        function setNativeValue(element, value) {
            const valueSetter = Object.getOwnPropertyDescriptor(element, 'value').set;
            const prototype = Object.getPrototypeOf(element);
            const prototypeValueSetter = Object.getOwnPropertyDescriptor(prototype, 'value').set;

            if (valueSetter && valueSetter !== prototypeValueSetter) {
                prototypeValueSetter.call(element, value);
            } else {
                valueSetter.call(element, value);
            }
            element.dispatchEvent(new Event('input', { bubbles: true }));
        }

        function processAutoSave() {
            const inputEl = document.querySelector('textarea.__chat_input_textarea, textarea[placeholder*="메시지"], div.__chat_input_textarea[contenteditable="true"], .tiptap.ProseMirror');
            if (!inputEl) return;

            const isEditor = inputEl.tagName !== 'TEXTAREA' && inputEl.isContentEditable;

            const newRoomId = getRoomId();
            if (currentRoomId !== newRoomId) {
                currentRoomId = newRoomId;
                isRestoredForCurrentRoom = false;
                inputEl.dataset.draftHooked = 'false';
            }

            const DRAFT_KEY = getDraftKey();

            if (!isRestoredForCurrentRoom) {
                const savedDraft = localStorage.getItem(DRAFT_KEY);
                const currentText = isEditor ? (inputEl.innerText || '') : (inputEl.value || '');
                
                if (savedDraft && currentText.trim() === '') {
                    if (isEditor) {
                        inputEl.focus();
                        document.execCommand("insertText", false, savedDraft);
                    } else {
                        setNativeValue(inputEl, savedDraft);
                    }
                }
                isRestoredForCurrentRoom = true;
            }

            if (inputEl.dataset.draftHooked !== 'true') {
                inputEl.dataset.draftHooked = 'true';
                inputEl.addEventListener('input', (e) => {
                    const text = isEditor ? e.target.innerText : e.target.value;
                    if (text.trim() === '') {
                        localStorage.removeItem(getDraftKey());
                    } else {
                        localStorage.setItem(getDraftKey(), text);
                    }
                });
            }
        }
        setInterval(processAutoSave, 1000);
    }

